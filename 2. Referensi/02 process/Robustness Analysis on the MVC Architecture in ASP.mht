class=3D"code-attribute">value</SPAN><SPAN =
class=3D"code-keyword">=3D"</SPAN><SPAN =
class=3D"code-keyword">MasterPageUserControl.ascx"</SPAN><SPAN =
class=3D"code-keyword">/</SPAN><SPAN class=3D"code-keyword">&gt;</SPAN>=0A=
  <SPAN class=3D"code-keyword">&lt;</SPAN><SPAN =

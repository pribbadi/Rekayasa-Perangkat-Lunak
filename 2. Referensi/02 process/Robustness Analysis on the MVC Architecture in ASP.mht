       <SPAN class=3D"code-attribute">value</SPAN><SPAN =
class=3D"code-keyword">=3D"</SPAN><SPAN =
class=3D"code-keyword">Provider=3DSQLOLEDB;server=3Dlocalhost;database=3D=
northwind;=0A=
                                        Integrated =
Security=3Dtrue;"</SPAN><SPAN class=3D"code-keyword">/</SPAN><SPAN =
class=3D"code-keyword">&gt;</SPAN>=0A=
<SPAN class=3D"code-keyword">&lt;</SPAN><SPAN =
